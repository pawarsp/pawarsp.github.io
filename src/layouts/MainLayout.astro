---
// src/layouts/MainLayout.astro
import Navbar from '../components/Navbar.tsx';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <!-- Added FontAwesome link for your icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
    <style>
      body {
        margin: 0;
        font-family: system-ui, sans-serif;
        background: #121212;
        color: #f5f5f5;
      }
      main {
        /* Boosted to 1050px so your grid has room to breath */
        max-width: 1050px; 
        margin: 2rem auto;
        padding: 0 1rem;
      }
    </style>
  </head>
  <body>
    <!-- Hydrates the React JS navbar -->
    <Navbar client:load />
    
    <main>
      <slot /> <!-- Your page content gets injected here -->
    </main>
  </body>
</html>