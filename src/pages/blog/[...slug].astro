---
import { getCollection, render } from 'astro:content'; // 1. Notice the 'render' import here!
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.id }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;

// 2. Pass the entire entry into the new render function
const { Content } = await render(entry); 
---

<MainLayout title={entry.data.title}>
  <p style="color: #888;">
    Published on {entry.data.pubDate.toLocaleDateString('en-US', { dateStyle: 'long' })}
  </p>
  <h1>{entry.data.title}</h1>
  
  <article style="line-height: 1.7; color: #e5e5e5;">
    <!-- 3. Renders your beautiful markdown text -->
    <Content />
  </article>

  <p style="margin-top: 3rem;">
    <a href="/blog" style="color: #38bdf8; text-decoration: none;">← Back to blog index</a>
  </p>
</MainLayout>